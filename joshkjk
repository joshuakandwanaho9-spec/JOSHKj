    <title>JOSHKK IT GADGETS</title>

    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 0;
            background-color: #f5f5f5;
        }

        header {
            background-color: #0a1f44;
            color: white;
            padding: 20px;
            text-align: center;
        }

        nav {
            background-color: #123a7a;
            padding: 10px;
            text-align: center;
        }

        nav a {
            color: white;
            margin: 0 15px;
            text-decoration: none;
            font-weight: bold;
        }

        nav a:hover {
